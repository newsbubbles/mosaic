# Mosaic API Key (required)
# Get from https://edit.mosaic.so
MOSAIC_API_KEY=mk_your_api_key_here

# OpenRouter API Key (required for agent)
OPENROUTER_API_KEY=your_openrouter_key

# Logfire API Key (optional, for observability)
LOGFIRE_API_KEY=your_logfire_key

# MCP Server Logging (optional)
LOGGER_NAME=mosaic_mcp
LOGGER_PATH=./mosaic_mcp.log
